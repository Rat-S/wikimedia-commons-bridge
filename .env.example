# Google Photos OAuth 2.0 Credentials
# Configure in Google Auth Platform console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Search Console Site Verification (Optional for Toolforge production)
GOOGLE_SITE_VERIFICATION_FILENAME=google1234567890.html
GOOGLE_SITE_VERIFICATION_CODE=google-site-verification: google1234567890.html

# Wikimedia OAuth 2.0 Credentials
# Register on meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration/propose/oauth2
WIKIMEDIA_CLIENT_ID=your-wikimedia-client-id
WIKIMEDIA_CLIENT_SECRET=your-wikimedia-client-secret

# Application URLs
# For local development:
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Session Encryption Key
SESSION_SECRET_KEY=generate-a-secure-random-string-with-at-least-32-characters

# Database Configuration Connection String
# SQLite (Local Dev): sqlite+aiosqlite:///./sessions.db
# MariaDB (Toolforge): mysql+aiomysql://<user>:<password>@<host>/<database>
DATABASE_URL=sqlite+aiosqlite:///./sessions.db
